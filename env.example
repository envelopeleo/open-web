# 複製成 .env 後填值： cp .env.example .env

# 你的 Anthropic API key（就是剛剛 curl 測通的那把）
ANTHROPIC_API_KEY=sk-ant-在這裡填入你的key

# Open WebUI 加密已儲存設定用，設了就不要改
# 產生： openssl rand -hex 32
WEBUI_SECRET_KEY=在這裡貼上產生的亂碼

# Open WebUI 連 LiteLLM 的內部金鑰，隨便一串即可（兩邊要一致，compose 已自動帶）
# 產生： openssl rand -hex 16
LITELLM_MASTER_KEY=sk-在這裡貼上另一串亂碼
