# ─────────────────────────────────────────────
#  複製這個檔成 .env，填入實際值後再啟動
#  指令： cp .env.example .env
# ─────────────────────────────────────────────

# 你的 Anthropic API key，從 https://console.anthropic.com 取得
# 格式類似 sk-ant-xxxxxxxx
ANTHROPIC_API_KEY=sk-ant-在這裡填入你的key

# Open WebUI 用來加密已儲存設定的金鑰
# 隨便一串長亂碼即可，但一旦設定後就不要再改（改了舊資料會解不開）
# 產生方法（任選一種）：
#   openssl rand -hex 32
#   python3 -c "import secrets; print(secrets.token_hex(32))"
WEBUI_SECRET_KEY=在這裡貼上產生的亂碼
