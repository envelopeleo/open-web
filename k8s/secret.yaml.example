# 機密：API key 與內部金鑰。
# 複製成 secret.yaml 後填入實際值： cp secret.yaml.example secret.yaml
# 注意：secret.yaml 含實際金鑰【不要推上 git】，已列入 .gitignore。
#
# stringData 讓你直接填明文，k8s 會自動幫你做 base64 編碼。
apiVersion: v1
kind: Secret
metadata:
  name: arch2-secrets
type: Opaque
stringData:
  ANTHROPIC_API_KEY: "sk-ant-在這裡填入你的key"
  LITELLM_MASTER_KEY: "sk-在這裡填入litellm金鑰"
  WEBUI_SECRET_KEY: "在這裡填入webui金鑰"
